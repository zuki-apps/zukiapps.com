{
  "name": "zuki-apps-website",
  "version": "1.0.0",
  "private": true,
  "description": "Marketing and legal website for Zuki Apps (zukiapps.com)",
  "homepage": "https://zukiapps.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuki-apps/zukiapps.com.git"
  },
  "bugs": {
    "url": "https://github.com/zuki-apps/zukiapps.com/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "build:static": "node scripts/static-export-build.mjs",
    "start": "next start",
    "preview": "set -a && . ./.env.cloudflare && set +a && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node scripts/static-export-build.mjs && node scripts/pages-deploy.mjs",
    "upload": "set -a && . ./.env.cloudflare && set +a && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "ci:check": "npx tsc --noEmit && npm run lint && npm run build:static",
    "ci:full": "npm run ci:check && npm run smoke:static",
    "smoke:static": "test -f out/index.html && test -f out/sitemap.xml",
    "messages:sync": "node scripts/sync-messages-from-en.mjs",
    "messages:report": "node scripts/sync-messages-report.mjs",
    "messages:apply-fun-facts": "node scripts/apply-fun-facts-translations.mjs",
    "images:compress": "node scripts/compress-public-images.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^9.0.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.553.0",
    "next": "^14.2.35",
    "next-intl": "^4.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.14.10",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "husky": "9.1.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.107.0"
  }
}
