# Copy to .dev.vars for local Cloudflare preview (`npm run preview`).
# Production secrets: Cloudflare dashboard → Workers → zukiapps-com → Settings → Variables.

NEXTJS_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SITEMAP_USE_GIT=true

# Server-only (set as encrypted Worker secrets in production)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
